{
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/builddir"
  ],
  "clang-tidy.buildPath": "${workspaceFolder}/builddir",
  "editor.wordWrapColumn": 99,
  "editorconfig.generateAuto": false,
  "files.associations": {
    ".clangd": "yaml",
    ".clang-format": "yaml",
    ".clang-tidy": "yaml",
  },
  "files.exclude": {
    "**/builddir/**": true,
  },
  "files.watcherExclude": {
    "**/builddir/**": true,
  },
  "mesonbuild.buildFolder": "${workspaceFolder}/builddir",
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": [
      "${workspaceFolder}/.github/**/*.yml",
    ],
  },
  "[cpp]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 8,
    "editor.useTabStops": false,
  },
}
