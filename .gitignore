# Ignore everything
*

# Include these specific files
!.clang-format
!.clang-tidy
!.clangd
!.editorconfig
!.gitignore
!LICENSE
!meson.build

# Include specific files from specific directories
!.github/
!.github/**/
!.github/**/*.md
!.github/**/*.y*ml

!.vscode/
