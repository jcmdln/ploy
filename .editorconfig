# SPDX-License-Identifier: ISC

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_size = 4
indent_style = space
tab_width = 4
trim_trailing_whitespace = true

[.clang{d,-{format,tidy}}]
indent_size = 2
tab_width = 2

[*.{c,h}pp]
indent_style = tab

[*.json{,c}]
indent_size = 2
tab_width = 2

[*.y{,a}ml]
indent_size = 2
tab_width = 2
